# NAS mount (CIFS/SMB) — rellena con tus credenciales
NAS_HOST=
NAS_SHARE=
NAS_USER=
NAS_PASS=

# Ruta base dentro del contenedor (lo que pones en Settings.library_path en la web)
LIBRARY_PATH=/media/instruccionales

# ElevenLabs API key (solo necesaria si cambias tts_engine=elevenlabs en settings)
ELEVENLABS_API_KEY=
# Motor TTS por defecto. Vacío = usa setting web (default s2pro).
DUBBING_TTS_ENGINE=

# Host directory containing s2-pro-q6_k.gguf + tokenizer.json. Mounted
# read-only at /models/s2pro inside dubbing-generator. Defaults to
# ./models/s2pro-gguf relative to the docker-compose file.
S2PRO_MODEL_DIR=./models/s2pro-gguf
