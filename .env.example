# NAS mount (CIFS/SMB) — rellena con tus credenciales
NAS_HOST=
NAS_SHARE=
NAS_USER=
NAS_PASS=

# Ruta base dentro del contenedor (lo que pones en Settings.library_path en la web)
LIBRARY_PATH=/media/instruccionales

# ElevenLabs API key (solo necesaria si cambias tts_engine=elevenlabs en settings)
ELEVENLABS_API_KEY=
# Motor TTS por defecto. Vacío = usa setting web (default xttsv2).
DUBBING_TTS_ENGINE=
